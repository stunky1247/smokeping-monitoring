# --- ROBLOX SERVICES SECTION ---
+ Roblox
menu = Roblox Services
title = Roblox Infrastructure (Last 3 Hours)
probe = Curl
urlformat = https://%host%/
remark = This section monitors the baseline health, API availability, and content delivery performance of the core Roblox network infrastructure.


++ Web_Portal
menu = Main Portal
title = Roblox Main Website (www)
host = www.roblox.com
remark = Measures the network response time to Roblox's primary front-end website to confirm if users can browse the homepage and load their dashboards.

++ Core_API
menu = Roblox API
title = Roblox API Engine (Microservices)
host = clientsettings.roblox.com
remark = Monitors backend authentication and configuration microservices to determine if the core database engine is up and allowing players to log in.

++ CDN_Static_Assets
menu = CDN Static
title = Roblox Content Delivery (rbxcdn Static)
host = static.rbxcdn.com
remark = Tracks the latency of basic image, icon, and user-interface asset delivery servers to ensure website elements load correctly.

++ CDN_Game_Assets
menu = CDN Game Files
title = Roblox Experience Asset Engine
host = assetdelivery.roblox.com
remark = Evaluates the download performance of heavy game data like meshes, clothing, and map textures to verify that experiences load completely.

