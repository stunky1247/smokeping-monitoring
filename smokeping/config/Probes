*** Probes ***

+ FPing
binary = /usr/sbin/fping
step = 60
pings = 20

+ FPing6
binary = /usr/sbin/fping
protocol = 6

+ DNS
binary = /usr/bin/dig
lookup = google.com
pings = 5
step = 300

+ TCPPing
binary = /usr/bin/tcpping
forks = 10
offset = random
pings = 20
port = 80

+ Curl
binary = /usr/bin/curl
forks = 5
offset = 50%
step = 60
pings = 20
urlformat = http://%host%/
extraargs = -s -S
